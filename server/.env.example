# ── Railway / production environment variables ────────────────────────────────
# Copy the variables below into the Railway API service's "Variables" panel.
# Do NOT commit actual values — this file only documents what is required.

# Required: long random string for signing JWTs.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Required: exact origin of your Railway static/frontend service, e.g.
# https://mathforces-frontend.up.railway.app
# Comma-separate to allow multiple origins (e.g. custom domain + railway subdomain).
FRONTEND_ORIGIN=

# Railway injects PORT automatically — do not set it here.
# API_PORT is only used for local development (falls back to 3001).
# API_PORT=3001

# ── Volume mount ───────────────────────────────────────────────────────────────
# Attach a Railway volume to /app/data on the API service.
# The SQLite database file will be created at /app/data/mathforces.db.
# (Resolved by server/src/db/database.ts: __dirname=dist/db → ../../data = /app/data)
